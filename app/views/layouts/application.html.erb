<!DOCTYPE html>
<html lang="<%= page_locale %>" dir="<%= locale_direction %>">
  <head>
    <title><%= content_for(:title) || "Writebook" %></title>

    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta charset="UTF-8">
    <meta name="color-scheme" content="light dark">
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no, interactive-widget=resizes-content">
    <meta name="view-transition" content="same-origin">
    <meta name="turbo-cache-control" content="no-cache">
    <meta name="page-direction" content="<%= page_locale %>-<%= locale_direction %>" data-turbo-track="reload">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <% if signed_in? %>
      <%= hide_from_user_style_tag %>
    <% end %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon.png" type="image/png">
    <link rel="apple-touch-icon" href="/app-icon.png">

    <%= stylesheet_link_tag :all, "data-turbo-track": "reload" %>
    <%= custom_styles_tag %>

    <%= javascript_importmap_tags %>
    <script>
      (function() {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored || (prefersDark ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>

  <body data-controller="fullscreen lightbox touch">
    <header id="header">
      <%= yield :header %>
    </header>

    <div id="toolbar">
      <%= yield :toolbar %>
    </div>

    <main id="main" class="<%= @layout_class %>">
      <%= yield %>
    </main>

    <aside id="sidebar" aria-label="Table of Contents">
      <%= yield :sidebar %>
    </aside>

    <footer id="footer">
      <%= yield :footer %>
    </footer>

    <%= render "layouts/lightbox" %>

    <% if Current.account&.enable_buymeacoffee? && Current.account&.buymeacoffee_identifier.present? %>
      <%
        selected_position = Current.account.buymeacoffee_position.presence || "Auto"
        widget_position = if selected_position == "Auto"
          locale_direction == "rtl" ? "left" : "right"
        else
          selected_position.downcase
        end
      %>
      <script data-turbo-eval="true">
        (function() {
          function loadBMCWidget() {
            // Remove existing Buy Me a Coffee widget container and iframe if any
            const existingBtn = document.getElementById("bmc-wbtn");
            if (existingBtn) existingBtn.remove();
            
            const existingContainer = document.querySelector(".bmc-btn-container");
            if (existingContainer) existingContainer.remove();

            const existingIframe = document.querySelector("iframe[src*='buymeacoffee']");
            if (existingIframe) existingIframe.remove();

            // Create new script tag dynamically to force browser execution
            const script = document.createElement("script");
            script.src = "https://cdnjs.buymeacoffee.com/1.0.0/widget.prod.min.js";
            script.setAttribute("data-name", "BMC-Widget");
            script.setAttribute("data-cfasync", "false");
            script.setAttribute("data-id", "<%= Current.account.buymeacoffee_identifier %>");
            script.setAttribute("data-description", "Support me on Buy me a coffee!");
            <% if Current.account.buymeacoffee_message.present? %>
              script.setAttribute("data-message", "<%= Current.account.buymeacoffee_message %>");
            <% end %>
            script.setAttribute("data-color", "<%= Current.account.buymeacoffee_color.presence || '#FFDD00' %>");
            script.setAttribute("data-position", "<%= widget_position %>");
            script.setAttribute("data-x_margin", "18");
            script.setAttribute("data-y_margin", "18");
            
            document.body.appendChild(script);
          }

          // Run on initial page load
          if (document.readyState === "complete" || document.readyState === "interactive") {
            loadBMCWidget();
          } else {
            document.addEventListener("DOMContentLoaded", loadBMCWidget);
          }

          // Run on every subsequent Turbo navigation
          document.addEventListener("turbo:load", loadBMCWidget);
        })();
      </script>
    <% end %>
  </body>
</html>
