<% content_for(:title) { "Custom styles" } %>

<% content_for :header do %>
  <nav>
    <%= link_to users_path, class: "btn" do %>
      <%= image_tag "arrow-left.svg", aria: { hidden: true }, size: 24 %>
      <span class="for-screen-reader">Go back</span>
    <% end %>

    <div class="breadcrumbs">
      <%= render "books/index_link" %>
      <span class="flex-item-no-shrink">▸</span>
      <%= image_tag "art.svg", aria: { label: "Custom styles" }, size: 19, class: "colorize--black", alt: "Custom styles" %>
    </div>
  </nav>
<% end %>

<div class="center pad txt-align-center flex flex-column">
  <%= form_with model: @account, url: account_custom_styles_url, class: "flex flex-column gap",
      data: { controller: "form", action: "keydown.ctrl+enter->form#submit keydown.meta+enter->form#submit" } do |form| %>
    <div class="pad-inline-double margin-inline">
      <div class="flex align-center gap-half center full-width justify-center">
        <h2 class="margin-none"><%= t('admin.library_direction') %></h2>
      </div>
      <p class="txt-subtle txt-align-center margin-none-block-start"><%= t('admin.library_direction_hint') %></p>

      <div class="flex gap justify-center margin-block">
        <% Account::LIBRARY_DIRECTIONS.each do |dir| %>
          <label class="btn <%= 'btn--reversed' if @account.library_direction == dir %>">
            <%= form.radio_button :library_direction, dir,
                id: "account_library_direction_#{dir}",
                data: { action: "change->form#submit" } %>
            <%= dir.upcase %>
          </label>
        <% end %>
      </div>
    </div>

    <hr class="margin-block">

    <div class="pad-inline-double margin-inline">
      <div class="flex align-center gap-half center full-width justify-center">
        <h2 class="margin-none"><%= t('admin.ui_language') %></h2>
      </div>
      <p class="txt-subtle txt-align-center margin-none-block-start"><%= t('admin.ui_language_hint') %></p>

      <div class="flex gap justify-center margin-block">
        <% Account::UI_LANGUAGES.each do |lang| %>
          <label class="btn <%= 'btn--reversed' if @account.ui_language == lang %>">
            <%= form.radio_button :ui_language, lang,
                id: "account_ui_language_#{lang}",
                data: { action: "change->form#submit" } %>
            <%= t("admin.language_#{lang}") %>
          </label>
        <% end %>
      </div>
    </div>

    <hr class="margin-block">

    <div class="pad-inline-double margin-inline">
      <div class="flex align-center gap-half center full-width justify-center">
        <h2 class="margin-none"><%= t('admin.buymeacoffee_title') %></h2>
      </div>
      <p class="txt-subtle txt-align-center margin-none-block-start"><%= t('admin.buymeacoffee_hint') %></p>

      <div class="flex flex-column gap margin-block text-align-start justify-center align-center" style="max-width: 480px; margin-inline: auto;">
        
        <label class="flex align-center gap cursor-pointer text-align-start full-width">
          <%= form.check_box :enable_buymeacoffee, style: "width: 20px; height: 20px;" %>
          <span><%= t('admin.buymeacoffee_enable') %></span>
        </label>

        <div class="flex flex-column full-width gap-half">
          <label for="account_buymeacoffee_identifier" class="txt--small text-align-start font-semibold" style="opacity: 0.7"><%= t('admin.buymeacoffee_identifier') %></label>
          <%= form.text_field :buymeacoffee_identifier, class: "input full-width", placeholder: "e.g. nunocoracao", autocomplete: "off" %>
        </div>

        <div class="flex flex-column full-width gap-half">
          <label for="account_buymeacoffee_message" class="txt--small text-align-start font-semibold" style="opacity: 0.7"><%= t('admin.buymeacoffee_message') %></label>
          <%= form.text_field :buymeacoffee_message, class: "input full-width", placeholder: "e.g. Support my work!", autocomplete: "off" %>
        </div>

        <div class="flex gap full-width">
          <div class="flex flex-column flex-item-grow gap-half">
            <label for="account_buymeacoffee_color" class="txt--small text-align-start font-semibold" style="opacity: 0.7"><%= t('admin.buymeacoffee_color') %></label>
            <div class="flex gap-half">
              <%= form.color_field :buymeacoffee_color, style: "width: 44px; height: 44px; padding: 2px; border: 1px solid var(--color-subtle-dark); border-radius: 6px; cursor: pointer; background: transparent;" %>
              <%= form.text_field :buymeacoffee_color, class: "input flex-item-grow", placeholder: "#FFDD00", style: "text-transform: uppercase;" %>
            </div>
          </div>

          <div class="flex flex-column gap-half" style="min-width: 160px;">
            <label class="txt--small text-align-start font-semibold" style="opacity: 0.7"><%= t('admin.buymeacoffee_position') %></label>
            <div class="flex gap-half">
              <% Account::BUYMEACOFFEE_POSITIONS.each do |pos| %>
                <label class="btn flex-item-grow <%= 'btn--reversed' if @account.buymeacoffee_position == pos %>" style="padding: 0.6em 0.8em; font-size: 0.9em;">
                  <%= form.radio_button :buymeacoffee_position, pos, id: "account_buymeacoffee_position_#{pos}" %>
                  <%= pos %>
                </label>
              <% end %>
            </div>
          </div>
        </div>

      </div>
    </div>

    <hr class="margin-block">

    <div class="pad-inline-double margin-inline">
      <div class="flex align-center gap-half center full-width justify-center">
        <span class="txt-medium"><%= translation_button(:custom_styles) %></span>
        <h1 class="margin-none"><%= t('admin.custom_css') %></h1>
      </div>
      <p class="flex flex-wrap align-center justify-center gap margin-none-block-start" style="--column-gap: 0.5ch; --row-gap: 0">
        <span><%= t('admin.custom_css_hint') %></span>
        <%= image_tag "alert.svg", class: "flex-inline colorize--black", size: 16, aria: { hidden: "true" } %>
        <span><%= t('admin.custom_css_warning') %></span>
      </p>
    </div>

    <label class="flex align-start gap flex-item-grow">
      <%= form.text_area :custom_styles, class: "input input--code txt--small", placeholder: "Add CSS styles…",
            autocomplete: "off", spellcheck: "false", autocorrect: "off", autocapitalize: "off",
            rows: 16, required: false %>
    </label>

    <%= form.button class: "btn btn--reversed center txt-large", type: "submit" do %>
      <%= image_tag "check.svg", aria: { hidden: "true" }, size: 20 %>
      <span class="for-screen-reader"><%= t('admin.save_changes') %></span>
    <% end %>
  <% end %>
</div>
